config lldpd 'config'
	option enable_cdp '1'
	option enable_fdp '1'
	option enable_sonmp '1'
	option enable_edp '1'
	option agentxsocket '/var/run/agentx.sock'
	option lldp_class '4'
	list interface 'loopback'
	list interface 'lan'
	option enabled '1'

	option lldp_platform 'AR-06-012H'
	option lldp_tx_interval '30'
	option lldp_tx_hold '4'
	option readonly_mode '0'
	option lldpmed_no_inventory '1'
	option lldp_portidsubtype 'ifname'
	option lldp_agenttype 'nearest-bridge'
	option force_lldp '1'
	option cdp_version 'cdpv1v2'