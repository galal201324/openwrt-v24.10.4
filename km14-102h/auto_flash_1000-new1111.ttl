;=========================================================
; سكربت التفليش التلقائي لأجهزة KT-KM14-102H
; سيقوم هذا السكربت بجميع الخطوات تلقائياً لـ 1000 جهاز
;=========================================================

; إعدادات المنفذ (قم بتغييرها لتناسب جهازك)
COM_PORT = '8'
BAUD_RATE = '115200'

; مسار ملف يامودم ومسار TFTP
UBOOT_YMODEM_FILE = 'D:\2026\u-boot-mt7621-kt-km14-102h.bin'
UBOOT_TFTP_FILE = 'u-boot-mt7621-kt-km14-102h.bin'

; 1. فتح الاتصال عبر المنفذ التسلسلي
COMMAND = '/C='
strconcat COMMAND COM_PORT
strconcat COMMAND ' /BAUD='
strconcat COMMAND BAUD_RATE
connect COMMAND

; إعداد مهلة الانتظار (Timeout) بالثواني
timeout = 180

; 2. انتظار رسالة Ymodem
wait 'Accepted mode is Ymoden-1K.' 'Ymodem'
if result=0 goto error_timeout

; 3. إرسال البوت لودر المؤقت عبر YMODEM
ymodemsend UBOOT_YMODEM_FILE
pause 2

; 4. انتظار ظهور قائمة البوت لودر والضغط على 3 للتحديث
wait 'ENTER to select' 'Press UP/DOWN to move'
pause 1
send '3'

; 5. تأكيد طلب إعادة التشغيل
wait 'Reboot after upgrading? (Y/n):'
pause 1
sendln 'y'

; 6. اختيار الوضع الافتراضي (TFTP)
wait 'Select (enter for default):'
sendln ''

; 7. الموافقة على آيبي البوت لودر
wait "Input U-Boot's IP address:"
sendln ''

; 8. الموافقة على آيبي السيرفر
wait "Input TFTP server's IP address:"
sendln ''

; 9. الموافقة على قناع الشبكة
wait "Input IP netmask:"
sendln ''

; 10. إدخال اسم ملف البوت لودر النهائي
wait "Input file name:"
sendln UBOOT_TFTP_FILE

; 11. انتظار الانتهاء بنجاح أو ظهور خطأ مسح الفلاش
wait '*** Bootloader upgrade completed! ***' '*** Flash erasure [0-5ffff] failed! ***'
if result=0 goto error_timeout
if result=2 goto flash_error_recovery

; 12. انتظار بوت قائمة الأوامر وإيقاف الإقلاع بالضغط على 0
wait 'Hit any key to stop autoboot:' 'U-Boot Boot Menu'
send '0'

:step_13
; 13. أوامر إصلاح جدول NMBM لقطاع Config
wait 'KM14-102H=>'
sendln 'nand read 0x84000000 0x80000 0x80000; nmbm nmbm0 erase 0x80000 0x80000; nmbm nmbm0 write 0x84000000 0x80000 0x80000'

; 14. أوامر إصلاح جدول NMBM لقطاع Factory
wait 'KM14-102H=>'
sendln 'nand read 0x84000000 0x100000 0x80000; nmbm nmbm0 erase 0x100000 0x80000; nmbm nmbm0 write 0x84000000 0x100000 0x80000'

; 15. سؤال هل تريد كتابة ملف الايبروم القوي
wait 'KM14-102H=>'
yesnobox 'هل تريد كتابة ملف الايبروم القوي؟' 'كتابة الايبروم'
if result=1 then
    sendln 'tftpboot 0x84000000 VIKOOMLINK-factory.bin; nmbm nmbm0 erase 0x100000 0x80000; nmbm nmbm0 write 0x84000000 0x100000 0x80000'
    wait 'KM14-102H=>'
endif

; 16. اعادة التشغيل
sendln 'reset'

; 17. انتظار قائمة البوت لودر والضغط على 2 لترقية الفايرموير
wait 'ENTER to select' 'Press UP/DOWN to move'
pause 1
send '2'

; 18. تشغيل الفايرموير بعد الترقية
wait 'Run firmware after upgrading? (Y/n):'
pause 1
sendln 'y'

; 19. اختيار الطريقة الافتراضية
wait 'Select (enter for default):'
sendln '0'

; 20. الموافقة على آيبي البوت لودر
wait "Input U-Boot's IP address:"
sendln ''

; 21. الموافقة على آيبي السيرفر
wait "Input TFTP server's IP address:"
sendln ''

; 22. الموافقة على قناع الشبكة
wait "Input IP netmask:"
sendln ''

; 23. إدخال اسم ملف الفايرموير
wait "Input file name:"
sendln 'openwrt-ramips-mt7621-kt_km14-102h-squashfs-factory.bin'

; 24. انتظار الانتهاء بنجاح
wait '*** Firmware image write completed! ***'
if result=0 goto error_timeout

messagebox 'تم تفليش وتجهيز الراوتر بنجاح! 🎉' 'عملية ناجحة 🎉'
disconnect 0
end

:flash_error_recovery
wait 'KM14-102H=>'
sendln 'nand erase.chip'

wait 'OK'
wait 'KM14-102H=>'
sendln 'nand scrub -y'

wait 'KM14-102H=>'
sendln 'tftpboot 0x84000000 u-boot-mt7621-kt-km14-102h.bin; nand erase 0x0 0x80000; nand write 0x84000000 0x0 0x80000'

wait 'KM14-102H=>'
messagebox 'تنبيه: الرجاء تعديل ملف Config-new-nand9999.bin الآن وإدخال الماك أدرس الملصق على الراوتر، ثم حفظ الملف.\nعند الانتهاء من الحفظ، اضغط "موافق" للمتابعة.' 'تعديل الماك أدرس مطلوب!'
sendln 'tftpboot 0x84000000 ‏‏Config-new-nand9999.bin; nand erase 0x80000 0x80000; nand write 0x84000000 0x80000 0x80000'

wait 'KM14-102H=>'
sendln 'tftpboot 0x84000000 ‏‏Factory-new-nand9999.bin; nand erase 0x00100000 0x00080000; nand write 0x84000000 0x00100000 0x00080000'

goto step_13

:error_timeout
messagebox 'حدث خطأ غير متوقع، أو تأخر الجهاز في الاستجابة.' 'خطأ ❌'
disconnect 0
end
