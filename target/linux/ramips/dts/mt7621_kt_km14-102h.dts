#include "mt7621.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "kt,km14-102h", "mediatek,mt7621-soc";
	model = "KT KM14-102H";

	aliases {
		led-boot = &led_wds;
		led-failsafe = &led_wds;
		led-running = &led_wlan;
		led-upgrade = &led_power;
		label-mac-device = &gmac0;
	};

	chosen {
		bootargs = "console=ttyS0,115200";
	};

	leds {
		compatible = "gpio-leds";

		led_power: mesh_red {
			label = "red:mesh";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
			default-state = "on";
		};

		led_wlan: wlan {
			label = "green:wlan";
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0radio";
		};

		mesh {
			label = "green:mesh";
			gpios = <&gpio 15 GPIO_ACTIVE_LOW>;
		};

		led_wds: wds {
			label = "blue:wds";
			gpios = <&switch0 9 GPIO_ACTIVE_HIGH>;
		};

		wan {
			label = "green:wan";
			gpios = <&switch0 0 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "mt7530-0:00:link";
		};

		lan {
			label = "green:lan";
			gpios = <&switch0 3 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "mt7530-0:01:link";
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&gpio 3 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};

		wps {
			label = "wps";
			gpios = <&gpio 4 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};

		led_switch {
			label = "led_switch";
			gpios = <&gpio 6 GPIO_ACTIVE_LOW>;
			linux,code = <0x21e>;
			linux,input-type = <0x5>;
		};
	};
};

&state_default {
	gpio {
		groups = "i2c", "jtag", "uart3", "wdt";
		function = "gpio";
	};
};

&gmac0 {
	nvmem-cells = <&macaddr_config_40004>;
	nvmem-cell-names = "mac-address";
};

&nand {
	status = "okay";

	mediatek,nmbm;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "Bootloader";
			reg = <0x0 0x80000>;
			read-only;
		};

		partition@80000 {
			label = "Config";
			reg = <0x80000 0x80000>;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				macaddr_config_40004: macaddr@40004 {
					reg = <0x40004 0x6>;
				};
			};
		};

		factory: partition@100000 {
			label = "Factory";
			reg = <0x100000 0x80000>;
		};

		partition@180000 {
			label = "kernel";
			reg = <0x180000 0x400000>;
		};

		partition@580000 {
			label = "ubi";
			reg = <0x580000 0x7280000>;
		};
	};
};

&pcie {
	status = "okay";
};

&pcie1 {
	wifi@0,0 {
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;
    mediatek,mtd-eeprom = <&factory 0x0>;
		mediatek,disable-radar-background;
	};
};

&switch0 {
	gpio-controller;
	#gpio-cells = <2>;

	ports {
		port@0 {
			status = "okay";
			label = "wan";
		};

		port@1 {
			status = "okay";
			label = "lan";
		};
	};
};